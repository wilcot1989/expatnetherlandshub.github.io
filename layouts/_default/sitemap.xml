{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{ range .Data.Pages }}
  {{- $isPillar := or (in .File.LogicalName "pillar") (in .File.LogicalName "beste-") (in .File.LogicalName "best-") -}}
  {{- $isReview := or (in .File.LogicalName "review") (in .File.LogicalName "vs-") -}}
  {{- $priority := "0.5" -}}
  {{- if .IsHome -}}{{- $priority = "1.0" -}}
  {{- else if eq .Kind "section" -}}{{- $priority = "0.9" -}}
  {{- else if $isPillar -}}{{- $priority = "0.9" -}}
  {{- else if $isReview -}}{{- $priority = "0.7" -}}
  {{- else if eq .Kind "page" -}}{{- $priority = "0.6" -}}
  {{- end -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ safeHTML ( .Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>
    {{- end }}
    <changefreq>{{ if .IsHome }}daily{{ else if eq .Kind "section" }}weekly{{ else }}monthly{{ end }}</changefreq>
    <priority>{{ $priority }}</priority>
  </url>
  {{ end }}
</urlset>

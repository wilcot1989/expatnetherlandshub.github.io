{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range .Data.Pages }}
  {{- if not (eq .Kind "taxonomy") }}
  {{- if not (eq .Kind "term") }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ safeHTML (.Lastmod.Format "2006-01-02T15:04:05-07:00") }}</lastmod>
    {{- end }}
    <changefreq>{{ if .IsHome }}daily{{ else if eq .Kind "section" }}weekly{{ else }}monthly{{ end }}</changefreq>
    <priority>{{ if .IsHome }}1.0{{ else if eq .Type "tools" }}0.9{{ else if eq .Kind "section" }}0.8{{ else if eq .Type "cities" }}0.8{{ else }}0.7{{ end }}</priority>
  </url>
  {{- end }}
  {{- end }}
  {{- end }}
  {{- /* Static tool pages — not in Hugo content pipeline */ -}}
  <url>
    <loc>https://expatnetherlandshub.com/tools/30-percent-ruling-calculator/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/salary-checker/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/health-insurance-wizard/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/bank-account-chooser/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/visa-permit-finder/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/bsn-planner/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://expatnetherlandshub.com/tools/insurance-chooser/</loc>
